# MongoDB Atlas connection string
# Get this from MongoDB Atlas → Connect → Drivers → Node.js
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/pending_orders?retryWrites=true&w=majority

# Port for the API server (Render.com sets this automatically)
PORT=4000

# Your Vercel frontend URL (set after deploying frontend)
FRONTEND_URL=https://your-app.vercel.app
